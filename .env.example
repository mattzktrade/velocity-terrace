# Production site URL (required for canonical URLs, sitemap, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://velocity-terrace.com

# Search Console verification (optional — paste meta tag content values only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Organization schema sameAs — comma-separated profile URLs (Instagram, LinkedIn, etc.)
NEXT_PUBLIC_SOCIAL_PROFILE_URLS=
